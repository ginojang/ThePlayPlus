# === PostgreSQL (ThePlayPlus) ===
# 실제 값으로 채운 뒤 .env 로 복사해서 사용하세요. (.env 는 git 에 커밋되지 않습니다)
PGHOST=your-db-host
PGPORT=5432
PGDATABASE=ThePlayPlus
PGUSER=your-db-user
PGPASSWORD=your-db-password

# 커넥션 풀 옵션
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000

# 단일 URL 방식을 쓸 경우 (비밀번호의 특수문자는 URL 인코딩 필요)
# DATABASE_URL=postgresql://user:password@host:5432/ThePlayPlus
